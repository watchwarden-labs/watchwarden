# WatchWarden — Environment Configuration
#
# Copy this file to .env and set all values before running.
# Generate secure random values: openssl rand -base64 32

# Controller — required on first startup (stored in DB after seeding)
ADMIN_PASSWORD=change-me-min-8-chars
JWT_SECRET=change-me-to-a-random-32-char-string!!!

# Controller — required on every startup
ENCRYPTION_KEY=change-me-to-a-random-32-char-string
ENCRYPTION_SALT=change-me-unique-per-deployment   # Required in production (throws if missing)

# PostgreSQL
POSTGRES_PASSWORD=change-me-strong-password

# CORS origin (required in production)
CORS_ORIGIN=http://localhost:8080

# Local agent auto-registration token
LOCAL_AGENT_TOKEN=change-me-to-a-random-token
